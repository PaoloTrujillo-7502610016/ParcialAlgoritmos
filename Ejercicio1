import java.util.Scanner;

public class Ejercicio1 {

    public static void main(String[] args) {

        //Declaramos variables
        double SALARIO = 1800000;//Salario base de todos los empleados
        int cantidadEmpleados;

        Scanner entrada = new Scanner(System.in);
        System.out.print("\nIngrese la cantidad de empleados: ");
        cantidadEmpleados = entrada.nextInt();
        int empleados[] = new int[cantidadEmpleados];


        // Ciclo para ingresar la antiguedad de cada uno de los empleados
        for (int i = 0; i < empleados.length; i++) {

            System.out.print("Ingrese antiguedad del empleado " + (i + 1) + " (años): ");
            empleados[i] = entrada.nextInt();
        }

        System.out.println("\n--- TOTAL DE UTILIDADES DE LOS EMPLEADOS ---\n");

        // Ciclo para mostrar los resultados de la utilidad
        for (int i = 0; i < empleados.length; i++) {
            double utilidad = calcularUtilidad(SALARIO, empleados[i]);
            System.out.println("La utilidad del empleado "+(i + 1)+" es de: $" + utilidad);
        }
    }

    // Metodo para calcular la utilidad
    public static double calcularUtilidad(double salario, int antiguedad) {

        if (antiguedad < 1) {
            return salario * 0.05;
        } else if (antiguedad < 2) {
            return salario * 0.07;
        } else if (antiguedad < 5) {
            return salario * 0.10;
        } else if (antiguedad < 10) {
            return salario * 0.15;
        } else {
            return salario * 0.20;
        }
    }
}
